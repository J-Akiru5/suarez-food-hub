# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database (Prisma - Supabase Session Pooler, port 5432)
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require&sslaccept=accept_invalid_certs

# App URLs
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_CUSTOMER_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_RIDER_URL=http://localhost:3003

# Admin seed credentials (only needed when running scripts/create-admin.ts locally, not required in Vercel)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=your_secure_password
