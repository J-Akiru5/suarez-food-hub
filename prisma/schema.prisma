generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  customer
  admin
  rider
  manager
}

enum OrderStatus {
  pending
  confirmed
  preparing
  out_for_delivery
  delivered
  cancelled
}

enum PaymentMethod {
  cod
  gcash
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum ProductAvailability {
  available
  sold_out
}

enum VariantType {
  none
  size
  preparation
  sugar_level
}

// ============================================
// MODELS
// ============================================

model Profile {
  id          String   @id @default(uuid()) @db.Uuid
  fullName    String   @map("full_name")
  role        UserRole @default(customer)
  phone       String   @default("N/A")
  address     String   @default("N/A")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  customerOrders Order[]   @relation("CustomerOrders")
  riderOrders    Order[]   @relation("RiderOrders")
  riderLocations RiderLocation[]

  @@map("profiles")
}

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  slug        String  @unique
  description String?
  imageUrl    String? @map("image_url")
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  products Product[]

  @@map("categories")
}

model Product {
  id           String             @id @default(uuid()) @db.Uuid
  name         String
  slug         String             @unique
  description  String?
  imageUrl     String?            @map("image_url")
  categoryId   String?            @map("category_id") @db.Uuid
  basePrice    Decimal            @map("base_price") @db.Decimal(10, 2)
  variantType  VariantType        @default(none) @map("variant_type")
  rating       Decimal            @default(5.0) @db.Decimal(3, 1)
  stocks       Int                @default(0)
  availability ProductAvailability @default(available)
  isFeatured   Boolean            @default(false) @map("is_featured")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  // Relations
  category  Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants  ProductVariant[]
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([availability])
  @@map("products")
}

model ProductVariant {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  name      String
  price     Decimal  @db.Decimal(10, 2)
  stocks    Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")

  // Relations
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model Order {
  id                String        @id @default(uuid()) @db.Uuid
  customerId        String        @map("customer_id") @db.Uuid
  status            OrderStatus   @default(pending)
  paymentMethod     PaymentMethod @map("payment_method")
  paymentStatus     PaymentStatus @default(pending) @map("payment_status")
  paymentProofUrl   String?       @map("payment_proof_url")
  gcashReferenceNo  String?       @map("gcash_reference_no")
  deliveryAddress   String        @map("delivery_address")
  deliveryContact   String        @map("delivery_contact")
  deliveryNotes     String?       @map("delivery_notes")
  deliveryLat       Decimal?      @map("delivery_location_lat") @db.Decimal(10, 7)
  deliveryLng       Decimal?      @map("delivery_location_lng") @db.Decimal(10, 7)
  riderId           String?       @map("rider_id") @db.Uuid
  subtotal          Decimal       @db.Decimal(10, 2)
  deliveryFee       Decimal       @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  riderEarnings     Decimal       @default(40.00) @map("rider_earnings") @db.Decimal(10, 2)
  completedAt       DateTime?     @map("completed_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  customer     Profile?       @relation("CustomerOrders", fields: [customerId], references: [id])
  rider        Profile?       @relation("RiderOrders", fields: [riderId], references: [id])
  items        OrderItem[]
  riderLocations RiderLocation[]

  @@index([customerId])
  @@index([riderId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  variantId   String? @map("variant_id") @db.Uuid
  productName String  @map("product_name")
  variantName String? @map("variant_name")
  quantity    Int     @default(1)
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(10, 2)

  // Relations
  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [productId], references: [id])
  variant ProductVariant?  @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model RiderLocation {
  id        String   @id @default(uuid()) @db.Uuid
  riderId   String   @map("rider_id") @db.Uuid
  orderId   String?  @map("order_id") @db.Uuid
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  updatedAt DateTime @default(now()) @map("updated_at")

  // Relations
  rider Profile @relation(fields: [riderId], references: [id])
  order Order?  @relation(fields: [orderId], references: [id])

  @@index([riderId])
  @@map("rider_locations")
}
