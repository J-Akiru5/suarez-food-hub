{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "apps/web": { "entry": ["app/**/*.{ts,tsx}"] },
    "apps/admin": {
      "entry": ["app/**/*.{ts,tsx}"],
      "ignoreDependencies": ["leaflet"]
    },
    "apps/staff": {
      "entry": ["app/**/*.{ts,tsx}"],
      "ignoreDependencies": ["leaflet"]
    },
    "apps/rider": { "entry": ["app/**/*.{ts,tsx}"] },
    "packages/ui": { "entry": ["src/**/*.{ts,tsx}"] },
    "packages/supabase": { "entry": ["src/**/*.ts"] }
  },
  "ignore": [
    "scripts/**",
    "apps/*/lib/**",
    "apps/*/components/LocationPicker.tsx",
    "apps/*/components/MapComponent.tsx",
    "apps/web/components/Navbar.tsx",
    "apps/web/components/AuthNavbar.tsx",
    "apps/rider/public/sw.js",
    "apps/rider/temp.css"
  ],
  "ignoreDependencies": ["@repo/supabase", "@types/leaflet", "pg", "turbo-ignore"],
  "ignoreBinaries": ["trufflehog"]
}
